# Cache-Control rules for Cloudflare Workers static asset serving.
# Versioned JS/CSS assets carry ?v=SHA so they can be cached indefinitely.
# index.html must never be cached so deploys reach browsers immediately.

/js/*
  Cache-Control: public, max-age=31536000, immutable

/styles/*
  Cache-Control: public, max-age=31536000, immutable

/*.html
  Cache-Control: no-cache, no-store, must-revalidate

/
  Cache-Control: no-cache, no-store, must-revalidate
